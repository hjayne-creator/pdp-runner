OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: primary PDP scraper for JS-heavy ecommerce pages.
# On hosts that define FIRECRAWL_API_KEY as an empty string, remove that var or set
# the real key there — backend loads .env with override so file values win over empties.
FIRECRAWL_API_KEY=
# Firecrawl cache max age in ms. Keep >0 to allow cached responses.
FIRECRAWL_MAX_AGE_MS=172800000
# Extra wait before scrape capture for late-hydrating content.
FIRECRAWL_WAIT_FOR_MS=1500
# Firecrawl scrape request timeout (ms) and SDK client timeout (ms).
FIRECRAWL_TIMEOUT_MS=120000
FIRECRAWL_CLIENT_TIMEOUT_MS=125000
# Scroll + wait actions require Fire Engine on your Firecrawl plan (off by default).
FIRECRAWL_ENABLE_SCROLL_ACTIONS=false
FIRECRAWL_ACTION_WAIT_MS=1200
# Firecrawl proxy mode; "auto" recommended.
FIRECRAWL_PROXY=auto

# Optional: Google search via SerpAPI for competitor PDP discovery (hl=en, gl=us).
# Enable per job with "Verify competitor PDPs" in the UI or verify_competitors in the API.
SERPAPI_API_KEY=
